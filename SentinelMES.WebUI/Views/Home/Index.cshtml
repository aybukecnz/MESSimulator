@model List<SentinelMES.WebUI.Models.AlertViewModel>

@{
    ViewData["Title"] = "SOC Komuta Merkezi";
}

<style>
    /* Ana Arka Planı Zorla Karanlık Yap */
    body, html, main {
        background-color: #0b0f19 !important;
        color: #e2e8f0 !important;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* Layout'tan Gelen Beyaz Üst Menüyü (Navbar) Karanlık Yap */
    header .navbar {
        background-color: #111827 !important;
        border-bottom: 1px solid #1f2937 !important;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    }

    header .navbar-brand, header .nav-link {
        color: #94a3b8 !important;
        font-weight: 600;
    }

        header .navbar-brand:hover, header .nav-link:hover {
            color: #60a5fa !important;
        }

    header .navbar .border-bottom {
        border-bottom: none !important;
    }

    /* Animasyonlar */
    .log-item-enter {
        animation: slideIn 0.3s ease-out forwards;
        border-left: 3px solid #ef4444;
        background: rgba(220, 38, 38, 0.1);
        margin-bottom: 0.5rem;
    }

    @@keyframes slideIn {
        from {
            transform: translateX(20px);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @@keyframes opacityPulse {
        0% {
            opacity: 0.5;
        }

        50% {
            opacity: 1;
        }

        100% {
            opacity: 0.5;
        }
    }

    .pulse-text {
        animation: opacityPulse 2s infinite;
    }

    /* Kart Tasarımları */
    .soc-card {
        background-color: #111827;
        border: 1px solid #1f2937;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
    }

    .soc-header {
        background: linear-gradient(90deg, #1f2937 0%, #111827 100%);
        border-bottom: 1px solid #374151;
        border-radius: 12px 12px 0 0;
    }

    .stat-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border-radius: 12px;
        border: none;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.7);
        }

    /* Tablolardaki Beyazlıkları Tamamen Ez (Force Dark Table) */
    .table {
        --bs-table-bg: transparent !important;
        color: #cbd5e1 !important;
        border-color: #1e293b !important;
        margin-bottom: 0;
    }

        .table td, .table th {
            background-color: #111827 !important;
            color: #cbd5e1 !important;
            border-bottom: 1px solid #1f2937 !important;
            padding: 1.2rem 0.75rem;
            vertical-align: middle;
        }

        .table tbody tr:hover td {
            background-color: #1e293b !important;
        }

        .table thead th {
            background-color: #1f2937 !important;
            color: #94a3b8 !important;
            border-bottom: 2px solid #374151 !important;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
        }

    /* Sekme (Tab) Tasarımları */
    .nav-pills .nav-link {
        color: #94a3b8;
        border-radius: 8px;
        margin: 0 5px;
        font-weight: 600;
        transition: all 0.3s;
        border: 1px solid transparent;
    }

        .nav-pills .nav-link:hover {
            background-color: #1e293b;
            color: #f8fafc;
        }

        .nav-pills .nav-link.active {
            background-color: rgba(37, 99, 235, 0.1);
            color: #60a5fa;
            border: 1px solid #2563eb;
            box-shadow: 0 0 15px rgba(37, 99, 235, 0.2);
        }

    /* Neon Rozetler */
    .badge-cyber {
        padding: 0.6em 0.9em;
        border-radius: 6px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .badge-glow-red {
        background-color: rgba(220, 38, 38, 0.1) !important;
        border: 1px solid #dc2626 !important;
        color: #ef4444 !important;
        box-shadow: 0 0 10px rgba(220, 38, 38, 0.2);
    }

    .badge-glow-yellow {
        background-color: rgba(217, 119, 6, 0.1) !important;
        border: 1px solid #d97706 !important;
        color: #f59e0b !important;
        box-shadow: 0 0 10px rgba(217, 119, 6, 0.2);
    }

    .badge-glow-blue {
        background-color: rgba(37, 99, 235, 0.1) !important;
        border: 1px solid #2563eb !important;
        color: #60a5fa !important;
        box-shadow: 0 0 10px rgba(37, 99, 235, 0.2);
    }

    /* Özel Kaydırma Çubuğu (Scrollbar) */
    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #0b0f19;
    }

    ::-webkit-scrollbar-thumb {
        background: #374151;
        border-radius: 4px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: #4b5563;
        }
</style>

<div class="container-fluid mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-white fw-bold mb-0"><i class="bi bi-radar text-primary"></i> Sentinel-MES SOC</h2>
            <small class="text-muted">Merkezi Siber Operasyon & Tehdit İstihbarat Ekranı</small>
        </div>
        <div class="d-flex gap-3 align-items-center">
            <span class="badge bg-success badge-cyber d-flex align-items-center px-3 py-2 fs-6">
                <span class="spinner-grow spinner-grow-sm me-2 text-light" role="status" aria-hidden="true"></span> Sistem Çevrimiçi
            </span>
            <button class="btn btn-primary fw-bold px-4" onclick="location.reload();">
                <i class="bi bi-arrow-clockwise me-1"></i> Paneli Yenile
            </button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card stat-card" style="background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase text-blue-200 small fw-bold mb-1" style="color: #bfdbfe;">Ağ Trafiği Durumu</h6>
                        <h3 class="text-white fw-bold mb-0">Canlı İzleme</h3>
                    </div>
                    <i class="bi bi-activity text-white opacity-50" style="font-size: 3rem;"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card" style="background: linear-gradient(135deg, #7f1d1d 0%, #991b1b 100%);">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase small fw-bold mb-1" style="color: #fca5a5;">Sistemdeki Toplam Tehdit</h6>
                        <h3 class="text-white fw-bold mb-0">@Model.Count <small class="fs-6 fw-normal">olay engellendi</small></h3>
                    </div>
                    <i class="bi bi-shield-x text-white opacity-50" style="font-size: 3rem;"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card" style="background: linear-gradient(135deg, #78350f 0%, #92400e 100%);">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase small fw-bold mb-1" style="color: #fcd34d;">Aktif Güvenlik Kuralı</h6>
                        <h3 class="text-white fw-bold mb-0">Zero-Trust Mimarisi</h3>
                    </div>
                    <i class="bi bi-fingerprint text-white opacity-50" style="font-size: 3rem;"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="card soc-card mt-2 mb-4" style="border-color: #0c4a6e;">
        <div class="card-header d-flex justify-content-between align-items-center" style="background-color: #082f49; border-bottom: 1px solid #0c4a6e; border-radius: 12px 12px 0 0;">
            <span class="text-info fw-bold"><i class="bi bi-geo-alt"></i> Canlı Siber Tehdit Radarı (Geo-IP)</span>
            <span class="badge bg-dark border border-info text-info pulse-text">SİSTEM AKTİF</span>
        </div>

        <div class="card-body p-0 d-flex" style="background-color: #020617; overflow: hidden; min-height: 350px;">

            <div class="col-md-7 d-flex justify-content-center align-items-center border-end p-4" style="border-color: #1e293b !important; position: relative;">
                <div style="width: 100%; height: 300px;">
                    <canvas id="threatChart"></canvas>
                </div>
                <div style="position: absolute; width: 100%; height: 100%; background: radial-gradient(circle, transparent 20%, rgba(2, 6, 23, 0.8) 80%); pointer-events: none;"></div>
            </div>

            <div class="col-md-5 p-4" style="font-family: monospace; font-size: 0.85rem; color: #38bdf8;">
                <h6 class="text-white border-bottom border-secondary pb-2 mb-3">
                    <i class="bi bi-shield-exclamation text-danger"></i> Son Engellenen Tehditler (Live)
                </h6>
                <div id="radarLogStream" class="d-flex flex-column" style="max-height: 280px; overflow-y: auto;">
                    <div class="text-muted text-center mt-5">Sistem dinleniyor... Bekleniyor.</div>
                </div>
            </div>

        </div>
    </div>



    <div class="soc-card mt-5">
        <div class="soc-header p-3">
            <ul class="nav nav-pills" id="socTabs" role="tablist">
                <li class="nav-item flex-fill text-center" role="presentation">
                    <button class="nav-link active py-3" data-bs-toggle="tab" data-bs-target="#network" type="button" role="tab">
                        <i class="bi bi-hdd-network"></i> Ağ İhlalleri (Dış Tehditler)
                    </button>
                </li>
                <li class="nav-item flex-fill text-center" role="presentation">
                    <button class="nav-link py-3" data-bs-toggle="tab" data-bs-target="#scada" type="button" role="tab">
                        <i class="bi bi-lightning-charge"></i> SCADA Anomalileri
                    </button>
                </li>
                <li class="nav-item flex-fill text-center" role="presentation">
                    <button class="nav-link py-3" data-bs-toggle="tab" data-bs-target="#insider" type="button" role="tab">
                        <i class="bi bi-incognito"></i> Kimlik & İç Tehditler
                    </button>
                </li>
            </ul>
        </div>

        <div class="card-body p-0">
            <div class="tab-content" id="socTabsContent">

                <div class="tab-pane fade show active" id="network" role="tabpanel">
                    <div class="table-responsive" style="max-height: 550px;">
                        <table class="table table-dark-custom mb-0">
                            <thead class="sticky-top">
                                <tr>
                                    <th style="width: 10%; padding-left: 1.5rem;">Olay ID</th>
                                    <th style="width: 15%;">Zaman Damgası</th>
                                    <th style="width: 20%;">Tehdit Vektörü</th>
                                    <th style="width: 10%;">Seviye</th>
                                    <th>İstihbarat Raporu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var alert in Model.Where(a => a.AlertType == "UNAUTHORIZED_IP_ACCESS"))
                                {
                                    <tr>
                                        <td class="text-muted fw-bold" style="padding-left: 1.5rem;">#@alert.AlertId</td>
                                        <td class="text-secondary font-monospace">@alert.Timestamp.ToString("HH:mm:ss | dd.MM.yyyy")</td>
                                        <td><span class="badge-cyber badge-glow-blue">@alert.AlertType</span></td>
                                        <td><span class="badge-cyber badge-glow-red">CRITICAL</span></td>
                                        <td class="text-light">@alert.Message</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="tab-pane fade" id="scada" role="tabpanel">
                    <div class="table-responsive" style="max-height: 550px;">
                        <table class="table table-dark-custom mb-0">
                            <thead class="sticky-top">
                                <tr>
                                    <th style="width: 10%; padding-left: 1.5rem;">Olay ID</th>
                                    <th style="width: 15%;">Zaman Damgası</th>
                                    <th style="width: 20%;">Telemetri Tehdidi</th>
                                    <th style="width: 10%;">Seviye</th>
                                    <th>Sistem Analizi</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var alert in Model.Where(a => a.AlertType == "OPERASYONEL_ANOMALI" || a.AlertType == "SİBER_ŞÜPHE"))
                                {
                                    <tr>
                                        <td class="text-muted fw-bold" style="padding-left: 1.5rem;">#@alert.AlertId</td>
                                        <td class="text-secondary font-monospace">@alert.Timestamp.ToString("HH:mm:ss | dd.MM.yyyy")</td>
                                        <td><span class="badge-cyber badge-glow-yellow">@alert.AlertType</span></td>
                                        <td><span class="badge-cyber badge-glow-red">CRITICAL</span></td>
                                        <td class="text-warning">@alert.Message</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="tab-pane fade" id="insider" role="tabpanel">
                    <div class="table-responsive" style="max-height: 550px;">
                        <table class="table table-dark-custom mb-0">
                            <thead class="sticky-top">
                                <tr>
                                    <th style="width: 10%; padding-left: 1.5rem;">Olay ID</th>
                                    <th style="width: 15%;">Zaman Damgası</th>
                                    <th style="width: 20%;">İhlal Türü</th>
                                    <th style="width: 10%;">Seviye</th>
                                    <th>Hedef & Kullanıcı Detayı</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var alert in Model.Where(a => a.AlertType != "UNAUTHORIZED_IP_ACCESS" && a.AlertType != "OPERASYONEL_ANOMALI" && a.AlertType != "SİBER_ŞÜPHE"))
                                {
                                    <tr>
                                        <td class="text-muted fw-bold" style="padding-left: 1.5rem;">#@alert.AlertId</td>
                                        <td class="text-secondary font-monospace">@alert.Timestamp.ToString("HH:mm:ss | dd.MM.yyyy")</td>
                                        <td><span class="badge-cyber badge-glow-blue text-info">@alert.AlertType</span></td>
                                        <td><span class="badge-cyber badge-glow-red">@alert.Severity</span></td>
                                        <td class="text-light">@alert.Message</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // 1. Chart.js Grafik Ayarları (Polar Area Chart)
            const ctx = document.getElementById('threatChart').getContext('2d');
            const threatChart = new Chart(ctx, {
                type: 'polarArea',
                data: {
                    labels: ['Russia', 'China', 'North Korea', 'Iran', 'Turkey'],
                    datasets: [{
                        label: 'Siber Saldırı Yoğunluğu',
                        data: [0, 0, 0, 0, 0], // İlk başta veriler sıfır, API dolduracak
                        backgroundColor: [
                            'rgba(220, 38, 38, 0.7)',  // Red - Russia
                            'rgba(217, 119, 6, 0.7)',  // Orange - China
                            'rgba(147, 51, 234, 0.7)', // Purple - North Korea
                            'rgba(234, 179, 8, 0.7)',  // Yellow - Iran
                            'rgba(34, 197, 94, 0.7)'   // Green - Turkey (İç Tehditler)
                        ],
                        borderColor: 'rgba(2, 6, 23, 1)', // Arka planla uyumlu koyu çizgi
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        r: {
                            grid: { color: 'rgba(56, 189, 248, 0.2)' }, // Radara benzeyen mavi ızgara
                            ticks: { display: false } // Rakamları gizle
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'right',
                            labels: { color: '#cbd5e1', font: { family: 'monospace', size: 12 } }
                        }
                    }
                }
            });

            // 2. WebAPI'den Canlı Veri Çekme Motoru
            async function fetchLiveThreats() {
                try {
                    // API isteğini atıyoruz (RadarController.cs içindeki metoda gider)
                    const response = await fetch('https://localhost:5001/api/Radar/live-threats');
                    if (!response.ok) return;

                    const threats = await response.json();

                    const logStream = document.getElementById('radarLogStream');

                    // Veri geldiyse "Bekleniyor" yazısını temizle
                    if (threats.length > 0 && logStream.innerHTML.includes("Bekleniyor")) {
                        logStream.innerHTML = '';
                    }

                    // Grafik için ülke sayısını tutan sözlük
                    let countryCounts = { 'Russia': 0, 'China': 0, 'North Korea': 0, 'Iran': 0, 'Turkey': 0 };

                    // Sadece yeni gelen logları eklemek için ekranı temizliyoruz (veya üstüne ekleyebilirsin)
                    logStream.innerHTML = '';

                    // 3. API'den gelen gerçek verileri UI'a bas
                    threats.forEach(t => {
                        // Log ekranına HTML olarak ekle
                        const logDiv = document.createElement('div');
                        logDiv.className = 'log-item-enter p-3 rounded text-light mb-2';
                        logDiv.style.backgroundColor = 'rgba(15, 23, 42, 0.8)';
                        logDiv.style.borderLeft = '4px solid #ef4444';

                        logDiv.innerHTML = `
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="text-danger fw-bold"><i class="bi bi-shield-x"></i> [ENGELLEME]</span>
                                <span class="text-muted small">${t.time}</span>
                            </div>
                            <div>Connection dropped from <b class="text-warning">${t.countryName} (${t.countryCode})</b></div>
                            <div class="small mt-1 text-secondary">IP: ${t.ip} | Rule: <span class="text-info">${t.attackType}</span></div>
                        `;
                        logStream.appendChild(logDiv);

                        // Grafik için gelen ülkenin sayısını artır
                        if(countryCounts[t.countryName] !== undefined) {
                            countryCounts[t.countryName]++;
                        }
                    });

                    // 4. Grafiği (Chart.js) Canlı Olarak Güncelle
                    threatChart.data.datasets[0].data = [
                        countryCounts['Russia'],
                        countryCounts['China'],
                        countryCounts['North Korea'],
                        countryCounts['Iran'],
                        countryCounts['Turkey']
                    ];
                    threatChart.update();

                } catch (error) {
                    console.error("API'den veri çekilirken hata:", error);
                }
            }

            // Her 3 saniyede bir WebAPI'ye gidip güncel siber tehditleri sor
            setInterval(fetchLiveThreats, 3000);

            // Sayfa açılır açılmaz ilk isteği at
            fetchLiveThreats();
        });
    </script>
}